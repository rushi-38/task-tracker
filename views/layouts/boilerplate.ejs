<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>
        Student Tracker
    </title>

    <!-- bootstrap -->

    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
    >

    <!-- custom css -->

    <link
        rel="stylesheet"
        href="/css/navbar.css"
    >

    <link
        rel="stylesheet"
        href="/css/task.css"
    >

    <link
        rel="stylesheet"
        href="/css/dashboard.css"
    >

</head>

<body>

    <!-- flash messages -->

    <%- include("../includes/flash") %>

    <!-- navbar -->

    <nav class="navbar navbar-expand-lg bg-body-tertiary">

        <div class="container-fluid">

            <!-- mobile toggle -->

            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarText"
            >

                <span class="navbar-toggler-icon"></span>

            </button>

            <!-- navbar content -->

            <div
                class="collapse navbar-collapse"
                id="navbarText"
            >

                <% if(currUser){ %>

                    <!-- left links -->

                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item links">

                            <a
                                class="nav-link"
                                href="/dashboard"
                            >
                                Dashboard
                            </a>

                        </li>

                        <li class="nav-item links">

                            <a
                                class="nav-link"
                                href="/addtask"
                            >
                                Add Task
                            </a>

                        </li>

                        <li class="nav-item links">

                            <a
                                class="nav-link"
                                href="/all_tasks"
                            >
                                All Tasks
                            </a>

                        </li>

                    </ul>

                    <!-- logout -->

                    <a
                        class="navbar-text lgsnup"
                        href="/logout"
                    >
                        Logout
                    </a>

                <% } else { %>

                    <!-- login signup -->

                    <div class="ms-auto">

                        <a
                            class="navbar-text lgsnup me-3"
                            href="/login"
                        >
                            Login
                        </a>

                        <a
                            class="navbar-text lgsnup"
                            href="/signup"
                        >
                            Signup
                        </a>

                    </div>

                <% } %>

            </div>

        </div>

    </nav>

    <!-- body -->

    <%- body %>

    <!-- bootstrap js -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>